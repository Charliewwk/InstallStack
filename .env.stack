# =========================
# Sistema
# =========================
TZ=America/Argentina/Buenos_Aires
COMPOSE_PROJECT_NAME=odoo_stack
LINUX_USER=enter your username here
LINUX_GROUP=enter your usergroup here

HOME_DIR=/home/enter your home here
SOURCE_ENV=/home/enter your home here/.env.stack
TARGET_ENV=/srv/.env

# =========================
# Paths
# =========================
BASE_DIR=/srv
ODOO_DIR=/srv/odoo
NGINX_DIR=/srv/nginx
POSTGRES_DIR=/srv/postgres
ONLYOFFICE_DIR=/srv/onlyoffice
OPENCLAW_DIR=/srv/openclaw
OLLAMA_DIR=/srv/ollama
BACKUPS_DIR=/srv/backups

# =========================
# PostgreSQL
# =========================
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=enter your password here

# =========================
# Odoo enter your ODOO CONFIG here
# =========================
ODOO_ADMIN_PASSWORD=enter your password here
ODOO_DB_HOST=db
ODOO_DB_PORT=5432
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=enter your password here
ODOO_WORKERS=5
ODOO_MAX_CRON_THREADS=2
ODOO_LIMIT_MEMORY_HARD=2684354560
ODOO_LIMIT_MEMORY_SOFT=2147483648
ODOO_LIMIT_REQUEST=8192
ODOO_LIMIT_TIME_CPU=600
ODOO_LIMIT_TIME_REAL=1200
ODOO_DBFILTER=.*

# =========================
# Dominios / Nginx / SSL
# =========================
ODOO_HOST=odoo.lan
DOCS_HOST=docs.odoo.lan
CLAW_HOST=claw.odoo.lan

SSL_COUNTRY=AR
SSL_STATE=Buenos_Aires
SSL_CITY=Ciudad_Autónoma_de_Buenos_Aires
SSL_ORG=Proyecto
SSL_UNIT=Infraestructura
SSL_COMMON_NAME=odoo.lan

# =========================
# OnlyOffice
# =========================
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=enter your JWT SECRET here
ONLYOFFICE_JWT_HEADER=Authorization
ONLYOFFICE_USE_UNAUTHORIZED_STORAGE=true

# =========================
# OpenClaw / Telegram
# =========================
OPENCLAW_GATEWAY_TOKEN=enter your GATEWAY TOKEN here
OPENCLAW_BIND=lan
OPENCLAW_PORT=18789
TELEGRAM_BOT_TOKEN=enter your TELEGRAM BOT TOKEN here
TELEGRAM_DM_POLICY=pairing
OPENCLAW_DEFAULT_MODEL=ollama/qwen2.5:3b-instruct (enter your DEFAULT MODEL here)
OPENCLAW_FALLBACK_MODEL=openai/gpt-4.1-mini  (enter your FALLBACK MODEL here)

# =========================
# Ollama
# =========================
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PROVIDER_API=ollama
OLLAMA_CONTEXT_WINDOW=32768
OLLAMA_MAX_TOKENS=8192